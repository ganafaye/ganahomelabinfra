# 1. Gestion de la page d'erreur personnalisée
ErrorDocument 404 /404.html

# 2. Redirection automatique vers HTTPS (Sécurité)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Masquer l'extension .php dans l'URL
# Permet d'accéder à site.com/contact au lieu de site.com/contact.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 4. Masquer l'extension .html (optionnel, si tu en as)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]